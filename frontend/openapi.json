          }
        },
        "required": [
          "section"
        ],
        "title": "StaleSectionState",
        "type": "object"
      },
      "TelemetryEvent": {
        "additionalProperties": false,
        "description": "Privacy-preserving. Raw prompt/response/document/transcript content is FORBIDDEN\nby construction (`extra='forbid'`) \u2014 attempting to attach raw content raises.",
        "properties": {
          "action_outcome": {
            "anyOf": [
              {
                "enum": [
                  "approved",
                  "edited",
                  "rejected"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Action Outcome"
          },
          "citation_coverage_score": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Citation Coverage Score"
          },
          "claim_support_score": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Claim Support Score"
          },
          "cost_bucket": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Cost Bucket"
          },
          "deterministic_rule_pass": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Deterministic Rule Pass"
          },
          "error_code": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Code"
          },
          "intent_class": {
            "title": "Intent Class",
            "type": "string"
          },
          "latency_bucket": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Latency Bucket"
          },
          "missing_evidence_code": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Missing Evidence Code"
          },
          "permission_denial_count": {
            "default": 0,
            "title": "Permission Denial Count",
            "type": "integer"
          },
          "recipe_id": {
            "title": "Recipe Id",
            "type": "string"
          },
          "schema_pass": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Schema Pass"
          },
          "source_type_counts": {
            "additionalProperties": true,
            "default": {},
            "title": "Source Type Counts",
            "type": "object"
          },
          "tool_attempted": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tool Attempted"
          },
          "tool_success": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Tool Success"
          }
        },
        "required": [
          "intent_class",
          "recipe_id"
        ],
        "title": "TelemetryEvent",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "VerticalScore": {
        "description": "Agent Ops vertical score shape from `frontend/src/data/ops.ts`.",
        "properties": {
          "metrics": {
            "additionalProperties": {
              "type": "number"
            },
            "title": "Metrics",
            "type": "object"
          },
          "passed": {
            "title": "Passed",
            "type": "integer"
          },
          "proves": {
            "title": "Proves",
            "type": "string"
          },
          "recipe": {
            "title": "Recipe",
            "type": "string"
          },
          "total": {
            "title": "Total",
            "type": "integer"
          }
        },
        "required": [
          "recipe",
          "passed",
          "total",
          "proves"
        ],
        "title": "VerticalScore",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "ConnectWork Command Agent \u2014 gateway",
    "version": "0.2.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/actions/compose": {
      "post": {
        "description": "Proposed follow-ups; every action carries a previewable diff or a `blocked_reason`.",
        "operationId": "post_actions_compose_actions_compose_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BriefRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ActionPlan"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Post Actions Compose"
      }
    },
    "/actions/execute": {
      "post": {
        "description": "Execute only approved, non-blocked actions. The plan is recomposed server-side, so a\nblocked action is never executed even if its index is submitted as approved.",
        "operationId": "post_actions_execute_actions_execute_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExecuteRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/AuditEvent"
                  },
                  "title": "Response Post Actions Execute Actions Execute Post",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Post Actions Execute"
      }
    },
